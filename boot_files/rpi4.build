################################################################################################
## ENV profile
################################################################################################
/etc/profile = {
export HOME=/
export SYSNAME=nto
export TERM=qansi
export PATH=/proc/boot:/sbin:/bin:/usr/bin:/usr/sbin:/usr/libexec
export LD_LIBRARY_PATH=/proc/boot:/lib:/usr/lib:/lib/dll:/lib/dll/pci

export PCI_HW_MODULE=/lib/dll/pci/pci_hw-bcm2711-rpi4.so
export PCI_DEBUG_MODULE=/lib/dll/pci/pci_debug2.so
export PCI_SLOG_MODULE=/lib/dll/pci/pci_slog2.so
export PCI_BKWD_COMPAT_MODULE=/lib/dll/pci/pci_bkwd_compat.so
}


################################################################################################
## Customize startup
################################################################################################
customize_startup.sh = {
#!/bin/ksh

if [ -e /scripts/board_startup.sh ]; then
    echo "Starting board customize script ..."
    ksh /scripts/board_startup.sh
fi
}



################################################################################################
## Script for launching the io-usb-otg
################################################################################################
usb_start.sh = {
#!/bin/sh
    VL805_VERSION=/dev/shmem/vl805_version.txt
    pci-tool -d 1:0:0 --read="CFG:0x50" > $VL805_VERSION
    if grep "50] 00000000" $VL805_VERSION > /dev/null; then
        echo "Inform vc to load vl805 firmware"
        mbox-bcm2711 notifyxhcireset=0x100000 > /dev/null 2>&1
    fi
    echo "Starting USB xHCI controller in the host mode (/dev/usb/*)..."
    io-usb-otg -t memory=below1G -d bcm2711-xhci pindex=0,memory=below1G
    waitfor /dev/usb/io-usb-otg
    waitfor /dev/usb/devu-hcd-bcm2711-xhci.so
}


################################################################################################
## Script for ota updates and verification
################################################################################################


[perms=0744] ota_update_ifs.sh = {
	#!/bin/ksh
	SCRIPT_VERSION="metrics-parser-v4"
	echo "SCRIPT_VERSION=$SCRIPT_VERSION"
	
	set -e
	
	NEW_IFS="$1"
	BOOT_DIR=/fs/boot
	OTA_DIR=/fs/boot/ota
	PRIMARY_IFS=$BOOT_DIR/ifs-rpi4.bin
	BACKUP_IFS=$OTA_DIR/ifs-rpi4.bin.bak
	STAGED_IFS=$OTA_DIR/ifs-rpi4.bin.new
	SUMMARY_FILE=$OTA_DIR/ota_summary.log
	RAW_TOP_FILE=$OTA_DIR/ota_top_raw.log
	SAMPLE_FILE=$OTA_DIR/ota_samples.csv
	
	if [ -z "$NEW_IFS" ]; then
	    echo "usage: ota_update_ifs.sh <new_ifs.bin>"
	    exit 1
	fi
	
	if [ ! -f "$NEW_IFS" ]; then
	    echo "update image not found: $NEW_IFS"
	    exit 1
	fi
	
	if [ ! -f "$PRIMARY_IFS" ]; then
	    echo "current boot image not found: $PRIMARY_IFS"
	    exit 1
	fi
	
	mkdir -p "$OTA_DIR"
	START_TS=`date +%s`
	: > "$RAW_TOP_FILE"
	: > "$SUMMARY_FILE"
	echo "cpu_tenths,ram_used_mb" > "$SAMPLE_FILE"
	(
	    while true
	    do
	        echo "sample `date +%s`" >> "$RAW_TOP_FILE"
	        top -bd -D 1 -i 1 >> "$RAW_TOP_FILE" 2>&1 || true
	        sleep 1
	    done
	) &
	
	SAMPLER_PID=$!
	
	cp "$PRIMARY_IFS" "$BACKUP_IFS"
	sync
	cp "$NEW_IFS" "$STAGED_IFS"
	sync
	mv "$STAGED_IFS" "$PRIMARY_IFS"
	sync
	kill $SAMPLER_PID 2>/dev/null||true
	wait $SAMPLER_PID 2>/dev/null||true
	
	END_TS=`date +%s`
	ELAPSED=$((END_TS-START_TS))
	
	CPU_SUM_TENTHS=0
	CPU_MAX_TENTHS=0
	RAM_SUM_MB=0
	RAM_MAX_MB=0
	COUNT=0
	CURRENT_CPU_TENTHS=
	
	while IFS= read LINE
	do
	    case "$LINE" in
	        "CPU states:"*)
	            PARSED_CPU=`echo "$LINE"|sed -n 's/.*CPU states: \\([0-9][0-9]*\\)\\.\\([0-9]\\)% user, \\([0-9][0-9]*\\)\\.\\([0-9]\\)% kernel.*/\\1\\2 \\3\\4/p'`
	            if [ -n "$PARSED_CPU" ]; then
	                set -- $PARSED_CPU
	                CURRENT_CPU_TENTHS=$(($1+$2))
	            else
	                CURRENT_CPU_TENTHS=
	            fi
	            ;;
	        "Memory:"*)
	            PARSED_MEM=`echo "$LINE" | sed -n 's/.*Memory: \\([0-9][0-9]*\\)M total, \\([0-9][0-9]*\\)M avail.*/\\1 \\2/p'`
	            if [ -n "$PARSED_MEM" -a -n "$CURRENT_CPU_TENTHS" ]; then
	                set -- $PARSED_MEM
	                RAM_USED_MB=$(($1-$2))
	
	                echo "$CURRENT_CPU_TENTHS,$RAM_USED_MB" >> "$SAMPLE_FILE"
	
	                COUNT=$((COUNT+1))
	                CPU_SUM_TENTHS=$((CPU_SUM_TENTHS + CURRENT_CPU_TENTHS))
	                RAM_SUM_MB=$((RAM_SUM_MB + RAM_USED_MB))
	
	                if [ "$CURRENT_CPU_TENTHS" -gt "$CPU_MAX_TENTHS" ]; then
	                    CPU_MAX_TENTHS=$CURRENT_CPU_TENTHS
	                fi
	
	                if [ "$RAM_USED_MB" -gt "$RAM_MAX_MB" ]; then
	                    RAM_MAX_MB=$RAM_USED_MB
	                fi
	
	                CURRENT_CPU_TENTHS=
	            fi
	            ;;
	    esac
	done < "$RAW_TOP_FILE"
	
	if [ "$COUNT" -gt 0 ]; then
	    CPU_AVG_HUND=$(((CPU_SUM_TENTHS * 10)/COUNT))
	    RAM_AVG_HUND=$(((RAM_SUM_MB * 100)/COUNT))
	else
	    CPU_AVG_HUND=0
	    RAM_AVG_HUND=0
	fi
	
	CPU_MAX_WHOLE=$((CPU_MAX_TENTHS/10))
	CPU_MAX_FRAC=$((CPU_MAX_TENTHS % 10))
	
	CPU_AVG_WHOLE=$((CPU_AVG_HUND/100))
	CPU_AVG_FRAC=$((CPU_AVG_HUND % 100))
	
	RAM_AVG_WHOLE=$((RAM_AVG_HUND/100))
	RAM_AVG_FRAC=$((RAM_AVG_HUND % 100))
	
	if [ "$CPU_AVG_FRAC" -lt 10 ]; then
	    CPU_AVG_FRAC=0$CPU_AVG_FRAC
	fi
	
	if [ "$RAM_AVG_FRAC" -lt 10 ]; then
	    RAM_AVG_FRAC=0$RAM_AVG_FRAC
	fi
	
	echo "Script version : $SCRIPT_VERSION" >> "$SUMMARY_FILE"
	echo "OTA start_epoch : $START_TS" >> "$SUMMARY_FILE"
	echo "OTA end_epoch : $END_TS" >> "$SUMMARY_FILE"
	echo "OTA time: $ELAPSED seconds" >> "$SUMMARY_FILE"
	echo "Max CPU used : $CPU_MAX_WHOLE.$CPU_MAX_FRAC %" >> "$SUMMARY_FILE"
	echo "Avg CPU used : $CPU_AVG_WHOLE.$CPU_AVG_FRAC %" >> "$SUMMARY_FILE"
	echo "Max RAM used : $RAM_MAX_MB MB" >> "$SUMMARY_FILE"
	echo "Avg RAM used : $RAM_AVG_WHOLE.$RAM_AVG_FRAC MB" >> "$SUMMARY_FILE"
	echo "Samples : $COUNT" >> "$SUMMARY_FILE"
	echo "New image : $NEW_IFS" >> "$SUMMARY_FILE"
	echo "Current image : $PRIMARY_IFS" >> "$SUMMARY_FILE"
	echo "Backup image : $BACKUP_IFS" >> "$SUMMARY_FILE"
	echo "Raw log : $RAW_TOP_FILE" >> "$SUMMARY_FILE"
	echo "OTA update complete"
	echo "Summary file : $SUMMARY_FILE"
	echo "Raw file : $RAW_TOP_FILE"
	echo "Samples file : $SAMPLE_FILE"
}

[perms=0744] ota_update_ifs_rsa.sh = {
	#!/bin/ksh
	SCRIPT_VERSION="rsa-validated-ota-v1"
	echo "SCRIPT_VERSION=$SCRIPT_VERSION"
	
	set -e
	
	NEW_IFS="$1"
	SIG_FILE="$2"
	
	BOOT_DIR=/fs/boot
	OTA_DIR=/fs/boot/ota
	PRIMARY_IFS=$BOOT_DIR/ifs-rpi4.bin
	BACKUP_IFS=$OTA_DIR/ifs-rpi4.bin.bak
	STAGED_IFS=$OTA_DIR/ifs-rpi4.bin.new
	
	PUBKEY=/etc/ota/rsapubkey.pem
	VERIFY_TOOL=/proc/boot/validate_rsa
	
	SUMMARY_FILE=$OTA_DIR/ota_summary.log
	RAW_TOP_FILE=$OTA_DIR/ota_top_raw.log
	SAMPLE_FILE=$OTA_DIR/ota_samples.csv
	
	if [ -z "$NEW_IFS" -o -z "$SIG_FILE" ]; then
	    echo "usage: ota_update_ifs_rsa.sh <new_ifs.bin> <signature.bin>"
	    exit 1
	fi
	
	if [ ! -f "$NEW_IFS" ]; then
	    echo "update image not found: $NEW_IFS"
	    exit 1
	fi
	
	if [ ! -f "$SIG_FILE" ]; then
	    echo "signature file not found: $SIG_FILE"
	    exit 1
	fi
	
	if [ ! -f "$PRIMARY_IFS" ]; then
	    echo "current boot image not found: $PRIMARY_IFS"
	    exit 1
	fi
	
	if [ ! -f "$PUBKEY" ]; then
	    echo "public key not found: $PUBKEY"
	    exit 1
	fi
	
	mkdir -p "$OTA_DIR"
	
	START_TS=`date +%s`
	: > "$RAW_TOP_FILE"
	: > "$SUMMARY_FILE"
	echo "cpu_tenths,ram_used_mb" > "$SAMPLE_FILE"
	
	(
	    while true
	    do
	        echo "SAMPLE `date +%s`" >> "$RAW_TOP_FILE"
	        top -bd -D 1 -i 1 >> "$RAW_TOP_FILE" 2>&1 || true
	        sleep 1
	    done
	) &
	
	SAMPLER_PID=$!
	
	VERIFY_START_TS=`date +%s`
	if ! $VERIFY_TOOL "$PUBKEY" "$NEW_IFS" "$SIG_FILE"; then
	    kill $SAMPLER_PID 2>/dev/null || true
	    wait $SAMPLER_PID 2>/dev/null || true
	    END_TS=`date +%s`
	    VERIFY_END_TS=`date +%s`
	    VERIFY_TIME=$((VERIFY_END_TS - VERIFY_START_TS))
	    ELAPSED=$((END_TS - START_TS))
	    echo "Script version: $SCRIPT_VERSION" >> "$SUMMARY_FILE"
	    echo "Validation: FAILED" >> "$SUMMARY_FILE"
	    echo "OTA start_epoch : $START_TS" >> "$SUMMARY_FILE"
	    echo "OTA end_epoch : $END_TS" >> "$SUMMARY_FILE"
	    echo "Verify time: $VERIFY_TIME seconds" >> "$SUMMARY_FILE"
	    echo "OTA time:$ELAPSED seconds" >> "$SUMMARY_FILE"
	    echo "New image:$NEW_IFS" >> "$SUMMARY_FILE"
	    echo "Signature file : $SIG_FILE" >> "$SUMMARY_FILE"
	    echo "Current image : $PRIMARY_IFS" >> "$SUMMARY_FILE"
	    echo "RSA validation failed update not installed"
	    exit 1
	fi
	VERIFY_END_TS=`date +%s`
	VERIFY_TIME=$((VERIFY_END_TS-VERIFY_START_TS))
	
	INSTALL_START_TS=`date +%s`
	
	cp "$PRIMARY_IFS" "$BACKUP_IFS"
	sync
	
	cp "$NEW_IFS" "$STAGED_IFS"
	sync
	
	mv "$STAGED_IFS" "$PRIMARY_IFS"
	sync
	
	INSTALL_END_TS=`date +%s`
	INSTALL_TIME=$((INSTALL_END_TS-INSTALL_START_TS))
	
	kill $SAMPLER_PID 2>/dev/null || true
	wait $SAMPLER_PID 2>/dev/null || true
	
	END_TS=`date +%s`
	ELAPSED=$((END_TS-START_TS))
	
	CPU_SUM_TENTHS=0
	CPU_MAX_TENTHS=0
	RAM_SUM_MB=0
	RAM_MAX_MB=0
	COUNT=0
	CURRENT_CPU_TENTHS=
	
	while IFS= read LINE
	do
	    case "$LINE" in
	        "CPU states:"*)
	            PARSED_CPU=`echo "$LINE" | sed -n 's/.*CPU states: \\([0-9][0-9]*\\)\\.\\([0-9]\\)% user, \\([0-9][0-9]*\\)\\.\\([0-9]\\)% kernel.*/\\1\\2 \\3\\4/p'`
	            if [ -n "$PARSED_CPU" ]; then
	                set -- $PARSED_CPU
	                CURRENT_CPU_TENTHS=$(( $1 + $2 ))
	            else
	                CURRENT_CPU_TENTHS=
	            fi
	            ;;
	        "Memory:"*)
	            PARSED_MEM=`echo "$LINE" | sed -n 's/.*Memory: \\([0-9][0-9]*\\)M total, \\([0-9][0-9]*\\)M avail.*/\\1 \\2/p'`
	            if [ -n "$PARSED_MEM" -a -n "$CURRENT_CPU_TENTHS" ]; then
	                set -- $PARSED_MEM
	                RAM_USED_MB=$(( $1 - $2 ))
	
	                echo "$CURRENT_CPU_TENTHS,$RAM_USED_MB" >> "$SAMPLE_FILE"
	
	                COUNT=$(( COUNT + 1 ))
	                CPU_SUM_TENTHS=$(( CPU_SUM_TENTHS + CURRENT_CPU_TENTHS ))
	                RAM_SUM_MB=$(( RAM_SUM_MB + RAM_USED_MB ))
	
	                if [ "$CURRENT_CPU_TENTHS" -gt "$CPU_MAX_TENTHS" ]; then
	                    CPU_MAX_TENTHS=$CURRENT_CPU_TENTHS
	                fi
	
	                if [ "$RAM_USED_MB" -gt "$RAM_MAX_MB" ]; then
	                    RAM_MAX_MB=$RAM_USED_MB
	                fi
	
	                CURRENT_CPU_TENTHS=
	            fi
	            ;;
	    esac
	done < "$RAW_TOP_FILE"
	
	if [ "$COUNT" -gt 0 ]; then
	    CPU_AVG_HUND=$(( (CPU_SUM_TENTHS * 10)/COUNT ))
	    RAM_AVG_HUND=$(( (RAM_SUM_MB * 100)/COUNT ))
	else
	    CPU_AVG_HUND=0
	    RAM_AVG_HUND=0
	fi
	
	CPU_MAX_WHOLE=$((CPU_MAX_TENTHS/10))
	CPU_MAX_FRAC=$((CPU_MAX_TENTHS % 10))
	
	CPU_AVG_WHOLE=$((CPU_AVG_HUND/100))
	CPU_AVG_FRAC=$((CPU_AVG_HUND % 100))
	
	RAM_AVG_WHOLE=$((RAM_AVG_HUND/100))
	RAM_AVG_FRAC=$((RAM_AVG_HUND % 100))
	
	if [ "$CPU_AVG_FRAC" -lt 10 ]; then CPU_AVG_FRAC=0$CPU_AVG_FRAC; fi
	if [ "$RAM_AVG_FRAC" -lt 10 ]; then RAM_AVG_FRAC=0$RAM_AVG_FRAC; fi
	
	echo "Script version : $SCRIPT_VERSION" >> "$SUMMARY_FILE"
	echo "Validation : PASSED" >> "$SUMMARY_FILE"
	echo "OTA start_epoch : $START_TS" >> "$SUMMARY_FILE"
	echo "OTA end_epoch : $END_TS" >> "$SUMMARY_FILE"
	echo "Verify time : $VERIFY_TIME seconds" >> "$SUMMARY_FILE"
	echo "Install time : $INSTALL_TIME seconds" >> "$SUMMARY_FILE"
	echo "OTA time : $ELAPSED seconds" >> "$SUMMARY_FILE"
	echo "Max CPU used : $CPU_MAX_WHOLE.$CPU_MAX_FRAC %" >> "$SUMMARY_FILE"
	echo "Avg CPU used : $CPU_AVG_WHOLE.$CPU_AVG_FRAC %" >> "$SUMMARY_FILE"
	echo "Max RAM used : $RAM_MAX_MB MB" >> "$SUMMARY_FILE"
	echo "Avg RAM used : $RAM_AVG_WHOLE.$RAM_AVG_FRAC MB" >> "$SUMMARY_FILE"
	echo "Samples : $COUNT" >> "$SUMMARY_FILE"
	echo "New image : $NEW_IFS" >> "$SUMMARY_FILE"
	echo "Signature file : $SIG_FILE" >> "$SUMMARY_FILE"
	echo "Current image : $PRIMARY_IFS" >> "$SUMMARY_FILE"
	echo "Backup image : $BACKUP_IFS" >> "$SUMMARY_FILE"
	echo "Raw top log : $RAW_TOP_FILE" >> "$SUMMARY_FILE"
	
	echo "RSA validation passed"
	echo "OTA update complete"
	echo "summary file : $SUMMARY_FILE"
	echo "raw file : $RAW_TOP_FILE"
	echo "samples file : $SAMPLE_FILE"
}


[perms=0744] ota_update_ifs_mldsa.sh = {
	#!/bin/ksh
	
	SCRIPT_VERSION="mldsa-validated-ota-v1"
	echo "SCRIPT_VERSION=$SCRIPT_VERSION"
	
	set -e
	
	NEW_IFS="$1"
	SIG_FILE="$2"
	
	BOOT_DIR=/fs/boot
	OTA_DIR=/fs/boot/ota
	PRIMARY_IFS=$BOOT_DIR/ifs-rpi4.bin
	BACKUP_IFS=$OTA_DIR/ifs-rpi4.bin.bak
	STAGED_IFS=$OTA_DIR/ifs-rpi4.bin.new
	
	PUBKEY=/etc/ota/mldsapubkey.bin
	VERIFY_TOOL=/proc/boot/validate_mldsa
	
	SUMMARY_FILE=$OTA_DIR/ota_summary.log
	RAW_TOP_FILE=$OTA_DIR/ota_top_raw.log
	SAMPLE_FILE=$OTA_DIR/ota_samples.csv
	
	if [ -z "$NEW_IFS" -o -z "$SIG_FILE" ]; then
	    echo "usage: ota_update_ifs_mldsa.sh <new_ifs.bin> <signature.bin>"
	    exit 1
	fi
	
	if [ ! -f "$NEW_IFS" ]; then
	    echo "update image not found: $NEW_IFS"
	    exit 1
	fi
	
	if [ ! -f "$SIG_FILE" ]; then
	    echo "signature file not found: $SIG_FILE"
	    exit 1
	fi
	
	if [ ! -f "$PRIMARY_IFS" ]; then
	    echo "current boot image not found: $PRIMARY_IFS"
	    exit 1
	fi
	
	if [ ! -f "$PUBKEY" ]; then
	    echo "public key not found: $PUBKEY"
	    exit 1
	fi
	
	mkdir -p "$OTA_DIR"
	
	START_TS=`date +%s`
	: > "$RAW_TOP_FILE"
	: > "$SUMMARY_FILE"
	echo "cpu_tenths,ram_used_mb" > "$SAMPLE_FILE"
	
	(
	    while true
	    do
	        echo "SAMPLE `date +%s`" >> "$RAW_TOP_FILE"
	        top -bd -D 1 -i 1 >> "$RAW_TOP_FILE" 2>&1 || true
	        sleep 1
	    done
	) &
	
	SAMPLER_PID=$!
	
	VERIFY_START_TS=`date +%s`
	if ! $VERIFY_TOOL "$PUBKEY" "$NEW_IFS" "$SIG_FILE"; then
	    kill $SAMPLER_PID 2>/dev/null || true
	    wait $SAMPLER_PID 2>/dev/null || true
	
	    END_TS=`date +%s`
	    VERIFY_END_TS=`date +%s`
	    VERIFY_TIME=$((VERIFY_END_TS - VERIFY_START_TS))
	    ELAPSED=$((END_TS - START_TS))
	
	    echo "Script version : $SCRIPT_VERSION" >> "$SUMMARY_FILE"
	    echo "Validation : FAILED" >> "$SUMMARY_FILE"
	    echo "OTA start_epoch : $START_TS" >> "$SUMMARY_FILE"
	    echo "OTA end_epoch : $END_TS" >> "$SUMMARY_FILE"
	    echo "Verify time : $VERIFY_TIME seconds" >> "$SUMMARY_FILE"
	    echo "OTA time : $ELAPSED seconds" >> "$SUMMARY_FILE"
	    echo "New image : $NEW_IFS" >> "$SUMMARY_FILE"
	    echo "Signature file : $SIG_FILE" >> "$SUMMARY_FILE"
	    echo "Current image : $PRIMARY_IFS" >> "$SUMMARY_FILE"
	   
	    echo "ML-DSA validation failed update not installed"
	    exit 1
	fi
	VERIFY_END_TS=`date +%s`
	VERIFY_TIME=$((VERIFY_END_TS - VERIFY_START_TS))
	
	INSTALL_START_TS=`date +%s`
	
	cp "$PRIMARY_IFS" "$BACKUP_IFS"
	sync
	
	cp "$NEW_IFS" "$STAGED_IFS"
	sync
	
	mv "$STAGED_IFS" "$PRIMARY_IFS"
	sync
	
	INSTALL_END_TS=`date +%s`
	INSTALL_TIME=$((INSTALL_END_TS - INSTALL_START_TS))
	
	kill $SAMPLER_PID 2>/dev/null || true
	wait $SAMPLER_PID 2>/dev/null || true
	
	END_TS=`date +%s`
	ELAPSED=$((END_TS-START_TS))
	
	CPU_SUM_TENTHS=0
	CPU_MAX_TENTHS=0
	RAM_SUM_MB=0
	RAM_MAX_MB=0
	COUNT=0
	CURRENT_CPU_TENTHS=
	
	while IFS= read LINE
	do
	    case "$LINE" in
	        "CPU states:"*)
	            PARSED_CPU=`echo "$LINE" | sed -n 's/.*CPU states: \\([0-9][0-9]*\\)\\.\\([0-9]\\)% user, \\([0-9][0-9]*\\)\\.\\([0-9]\\)% kernel.*/\\1\\2 \\3\\4/p'`
	            if [ -n "$PARSED_CPU" ]; then
	                set -- $PARSED_CPU
	                CURRENT_CPU_TENTHS=$(($1+$2))
	            else
	                CURRENT_CPU_TENTHS=
	            fi
	            ;;
	        "Memory:"*)
	            PARSED_MEM=`echo "$LINE" | sed -n 's/.*Memory: \\([0-9][0-9]*\\)M total, \\([0-9][0-9]*\\)M avail.*/\\1 \\2/p'`
	            if [ -n "$PARSED_MEM" -a -n "$CURRENT_CPU_TENTHS" ]; then
	                set -- $PARSED_MEM
	                RAM_USED_MB=$(( $1 - $2 ))
	
	                echo "$CURRENT_CPU_TENTHS,$RAM_USED_MB" >> "$SAMPLE_FILE"
	
	                COUNT=$(( COUNT + 1 ))
	                CPU_SUM_TENTHS=$(( CPU_SUM_TENTHS + CURRENT_CPU_TENTHS ))
	                RAM_SUM_MB=$(( RAM_SUM_MB + RAM_USED_MB ))
	
	                if [ "$CURRENT_CPU_TENTHS" -gt "$CPU_MAX_TENTHS" ]; then
	                    CPU_MAX_TENTHS=$CURRENT_CPU_TENTHS
	                fi
	
	                if [ "$RAM_USED_MB" -gt "$RAM_MAX_MB" ]; then
	                    RAM_MAX_MB=$RAM_USED_MB
	                fi
	
	                CURRENT_CPU_TENTHS=
	            fi
	            ;;
	    esac
	done < "$RAW_TOP_FILE"
	
	if [ "$COUNT" -gt 0 ]; then
	    CPU_AVG_HUND=$(((CPU_SUM_TENTHS * 10)/COUNT))
	    RAM_AVG_HUND=$(((RAM_SUM_MB * 100)/COUNT))
	else
	    CPU_AVG_HUND=0
	    RAM_AVG_HUND=0
	fi
	
	CPU_MAX_WHOLE=$((CPU_MAX_TENTHS/10))
	CPU_MAX_FRAC=$((CPU_MAX_TENTHS % 10))
	
	CPU_AVG_WHOLE=$((CPU_AVG_HUND/100))
	CPU_AVG_FRAC=$((CPU_AVG_HUND % 100))
	
	RAM_AVG_WHOLE=$((RAM_AVG_HUND/100))
	RAM_AVG_FRAC=$((RAM_AVG_HUND % 100))
	
	if [ "$CPU_AVG_FRAC" -lt 10 ]; then CPU_AVG_FRAC=0$CPU_AVG_FRAC; fi
	if [ "$RAM_AVG_FRAC" -lt 10 ]; then RAM_AVG_FRAC=0$RAM_AVG_FRAC; fi
	
	echo "Script version : $SCRIPT_VERSION" >> "$SUMMARY_FILE"
	echo "Validation : PASSED" >> "$SUMMARY_FILE"
	echo "OTA start_epoch : $START_TS" >> "$SUMMARY_FILE"
	echo "OTA end_epoch : $END_TS" >> "$SUMMARY_FILE"
	echo "Verify time : $VERIFY_TIME seconds" >> "$SUMMARY_FILE"
	echo "Install time : $INSTALL_TIME seconds" >> "$SUMMARY_FILE"
	echo "OTA time : $ELAPSED seconds" >> "$SUMMARY_FILE"
	echo "Max CPU used : $CPU_MAX_WHOLE.$CPU_MAX_FRAC %" >> "$SUMMARY_FILE"
	echo "Avg CPU used : $CPU_AVG_WHOLE.$CPU_AVG_FRAC %" >> "$SUMMARY_FILE"
	echo "Max RAM used : $RAM_MAX_MB MB" >> "$SUMMARY_FILE"
	echo "Avg RAM used : $RAM_AVG_WHOLE.$RAM_AVG_FRAC MB" >> "$SUMMARY_FILE"
	echo "Samples : $COUNT" >> "$SUMMARY_FILE"
	echo "New image : $NEW_IFS">> "$SUMMARY_FILE"
	echo "Signature file : $SIG_FILE">> "$SUMMARY_FILE"
	echo "Current image : $PRIMARY_IFS" >> "$SUMMARY_FILE"
	echo "Backup image : $BACKUP_IFS" >> "$SUMMARY_FILE"
	echo "Raw log : $RAW_TOP_FILE">> "$SUMMARY_FILE"
	
	echo "ML-DSA validation passed"
	echo "OTA update complete"
	echo "Summary file : $SUMMARY_FILE"
	echo "Raw top file : $RAW_TOP_FILE"
	echo "Samples file : $SAMPLE_FILE"
}

################################################################################################
## GPIO utility
################################################################################################
/bin/gpio-bcm2711=gpio-bcm2711

################################################################################################
## Mailbox utility
################################################################################################
/bin/mbox-bcm2711=mbox-bcm2711

